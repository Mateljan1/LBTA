{
  "name": "laguna-beach-tennis-academy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "./node_modules/.bin/next build",
    "start": "next start",
    "lint": "./node_modules/.bin/eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "./node_modules/.bin/vitest run",
    "tokens:build": "./node_modules/.bin/tsx scripts/build-tokens.ts",
    "tokens:check": "./node_modules/.bin/tsx scripts/check-brand-usage.ts",
    "check:env": "node scripts/check-ac-ghl-env.js",
    "lead": "node scripts/lead.js",
    "connection-check": "node scripts/connection-check.js",
    "smoke:lead": "node scripts/smoke-lead.js",
    "check:vercel": "npx vercel whoami && npx vercel list --yes",
    "lighthouse": "npx lighthouse http://localhost:3000 --output=html --output-path=./docs/lighthouse-report.html --only-categories=performance,accessibility,best-practices,seo --chrome-flags='--headless'",
    "capture:emails": "./node_modules/.bin/tsx scripts/capture-emails.ts",
    "capture:notifications": "./node_modules/.bin/tsx scripts/capture-notifications.ts",
    "quality-gate": "npm run tokens:build && npm run tokens:check && npm run build && npm run lint",
    "ship:gate": "bash scripts/ship-gate.sh",
    "fact-check": "node scripts/fact-check.js",
    "verify:images": "node scripts/verify-image-paths.mjs",
    "create:spring-campaign": "node scripts/create-ac-campaign.js assets/emails/lbta-spring-2026.html",
    "build:schedule-pdf": "node scripts/generate-schedule-pdf.mjs",
    "build:court-flyer-pdf-standalone": "./node_modules/.bin/tsx scripts/generate-court-flyer-pdf-standalone.ts"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.4.3",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "cloudinary": "^2.9.0",
    "framer-motion": "^11.11.17",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.462.0",
    "next": "^16.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.0",
    "server-only": "^0.0.1",
    "stripe": "^17.7.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sanitize-html": "^2.16.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "jsdom": "^25.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^2.1.6"
  }
}
