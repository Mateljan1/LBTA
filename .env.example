# Laguna Beach Tennis Academy — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local or real secrets.
# See README "Environment variables" and lib/env.ts for details.

# Site (optional; used for canonical URLs, sitemaps)
NEXT_PUBLIC_SITE_URL=https://lagunabeachtennisacademy.com

# ActiveCampaign — required for form submissions (book, register, newsletter, etc.)
ACTIVECAMPAIGN_URL=
ACTIVECAMPAIGN_API_KEY=

# ActiveCampaign webhook — required in production for inbound automation
AC_WEBHOOK_SECRET=

# Notion (optional — for registration integrations)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Vercel KV — optional; used for API rate limiting when set
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase — optional; when set, form submissions are stored in leads table
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics (optional; app works without these; IDs may be hardcoded in layout)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
