# Laguna Beach Tennis Academy — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local or real secrets.
# See README "Environment variables" and lib/env.ts for details.

# Site (optional; used for canonical URLs, sitemaps)
NEXT_PUBLIC_SITE_URL=https://lagunabeachtennisacademy.com

# ─────────────────────────────────────────────────────────────
# Mailchimp — PRIMARY lead destination for all website forms
# API key format: xxxx-usN (server prefix is the suffix after the last hyphen)
# Get from: Mailchimp → Account → Extras → API Keys
# Audience ID: 30bbabe32c (Laguna Beach Tennis Academy, 2,641 members)
# Server prefix: us1
# ─────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_AUDIENCE_ID=30bbabe32c

# ActiveCampaign — DEPRECATED (being retired per org policy)
# Keys still present for backwards compat; routes skip AC when ACTIVECAMPAIGN_API_KEY is empty.
# Remove these after verifying Mailchimp is stable (target: 2026-07).
ACTIVECAMPAIGN_URL=https://tennisbeast.api-us1.com
ACTIVECAMPAIGN_API_KEY=
ACTIVECAMPAIGN_WEBSITE_SIGNUPS_LIST_ID=

# ActiveCampaign webhook — required only if AC is still active
AC_WEBHOOK_SECRET=

# Coach Hub — optional; when set, /coach-hub is protected by this password (cookie-signed)
COACH_HUB_SECRET=

# UTR Tracker Admin — optional; when set, /utr-tracker/admin is protected by this password (cookie-signed)
UTR_TRACKER_ADMIN_SECRET=

# Agent Tools — optional; when set, agent tools can call APIs with X-Agent-Secret header
# Required for production agent tool calls; optional in dev (tools work without it if not set)
AGENT_SECRET=

# Notion (optional — for registration integrations)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Coach Hub · Match Day → Notion Match Results sync (all optional; app works local-only when unset)
# Parent database ID of the Notion "Match Results" database.
NOTION_MATCH_RESULTS_DB_ID=
# Optional dedicated integration token for Match Results; falls back to NOTION_API_KEY when blank.
NOTION_MATCH_RESULTS_TOKEN=
# Capability token the gated /coach-hub/matchday page hands to authenticated coaches; the
# /api/coach-hub/matchday/sync route requires it. Generate any long random string.
MATCHDAY_SYNC_TOKEN=

# Vercel KV — optional; used for API rate limiting when set
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase — optional; when set, form submissions are stored in leads table
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary — optional; when set, homepage "Our Community" masonry appends images from folder `lbta_website/community`
# Format: cloudinary://<API_KEY>:<API_SECRET>@<cloud_name>
CLOUDINARY_URL=

# GoHighLevel — optional; when set, form submissions create/find contact and add to SMS workflow
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WORKFLOW_ID=
# When GHL_API_KEY + GHL_LOCATION_ID + GHL_WORKFLOW_ID are set, staff/customer
# emails skip Postmark and run through the GHL workflow (SMS + email in GHL UI).
# Set to false to keep Postmark alongside GHL.
# LEADS_DELIVERY_GHL_ONLY=false
# GHL Chat Widget: location ID for the Conversation AI web chat widget.
# Get from GHL > Sites > Chat Widget > Get Code. The location-id attribute value.
# When set, the GHL native chat widget renders on all pages (replaces the stub chat).
NEXT_PUBLIC_GHL_CHAT_WIDGET_LOCATION_ID=
# GHL Private Integration Token — used by chatbot webhook to send SMS responses.
# Get from GHL > Settings > Integrations > Private Integration > API Key (PIT token).
GHL_PIT_TOKEN=

# Poppy AI — powers the chatbot webhook with Claude + LBTA knowledge base
# Get from Poppy board > API button > Show more
POPPY_API_KEY=
POPPY_BOARD_ID=merry-fire-cvo3i
POPPY_CHAT_ID=chatNode-silly-valley-mDFea
POPPY_MODEL=claude-sonnet-4-6

# Stripe — optional; UTR Match Play Series full-season registration uses Checkout when set.
# Webhook URL: https://<your-domain>/api/webhooks/stripe (checkout.session.completed).
# SECURITY: Set only in Vercel (Production/Preview) or .env.local — never commit real values.
# If a secret was exposed (chat, screenshot, PR), rotate it in Stripe Dashboard immediately.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional — only if you add Stripe.js/Elements on the client; hosted Checkout does not require this.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Postmark — optional; when set, form submissions send notification emails to staff
POSTMARK_SERVER_TOKEN=
# Optional: override the default "from" address (default: support@lagunabeachtennisacademy.com)
# POSTMARK_FROM_EMAIL=
# Optional: comma-separated emails for lead notification delivery
# Defaults to support@lagunabeachtennisacademy.com when unset
# Example: andrew@tennisbeast.com,support@lagunabeachtennisacademy.com
NOTIFICATION_EMAILS=

# Cron auth for /api/cron/* routes
CRON_SECRET=

# City-payment follow-up owner tags (optional overrides)
# Used by city-payment-followups automation for 2h / 24h / 72h escalation.
# FOLLOWUP_TIER_2H_OWNER_TAG=City Payment Owner - Front Desk
# FOLLOWUP_TIER_24H_OWNER_TAG=City Payment Owner - Enrollment
# FOLLOWUP_TIER_72H_OWNER_TAG=City Payment Owner - Director

# Analytics (optional; app works without these; IDs may be hardcoded in layout)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
