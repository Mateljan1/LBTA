# Laguna Beach Tennis Academy — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local or real secrets.
# See README "Environment variables" and lib/env.ts for details.

# Site (optional; used for canonical URLs, sitemaps)
NEXT_PUBLIC_SITE_URL=https://lagunabeachtennisacademy.com

# ActiveCampaign — required for form submissions (book, register, newsletter, etc.)
# API URL is shown in AC → Settings → Developer (e.g. LBTA account: https://tennisbeast.api-us1.com)
ACTIVECAMPAIGN_URL=https://tennisbeast.api-us1.com
ACTIVECAMPAIGN_API_KEY=
# Optional: list ID for "LBTA Website Signups". When set, only website signups are added to this list;
# the single confirmation automation should trigger only on this list (not List 4 or tags).
ACTIVECAMPAIGN_WEBSITE_SIGNUPS_LIST_ID=

# ActiveCampaign webhook — required in production for inbound automation
AC_WEBHOOK_SECRET=

# Coach Hub — optional; when set, /coach-hub is protected by this password (cookie-signed)
COACH_HUB_SECRET=

# Agent Tools — optional; when set, agent tools can call APIs with X-Agent-Secret header
# Required for production agent tool calls; optional in dev (tools work without it if not set)
AGENT_SECRET=

# Notion (optional — for registration integrations)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Vercel KV — optional; used for API rate limiting when set
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase — optional; when set, form submissions are stored in leads table
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary — optional; when set, homepage "Our Community" masonry appends images from folder `lbta_website/community`
# Format: cloudinary://<API_KEY>:<API_SECRET>@<cloud_name>
CLOUDINARY_URL=

# GoHighLevel — optional; when set, form submissions create/find contact and add to SMS workflow
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WORKFLOW_ID=

# Postmark — optional; when set, form submissions send notification emails to staff
POSTMARK_SERVER_TOKEN=
# Optional: override the default "from" address (default: support@lagunabeachtennisacademy.com)
# POSTMARK_FROM_EMAIL=

# Analytics (optional; app works without these; IDs may be hardcoded in layout)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
