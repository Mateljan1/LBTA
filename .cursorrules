## File Structure Conventions

```
app/
├── (routes)/
│   ├── page.tsx           # Homepage
│   ├── programs/
│   │   ├── page.tsx       # Programs overview
│   │   ├── junior/page.tsx
│   │   ├── adult/page.tsx
│   │   └── high-performance/page.tsx
│   ├── coaches/
│   │   ├── page.tsx       # Coaches grid
│   │   └── [slug]/page.tsx
│   ├── schedules/page.tsx
│   ├── pricing/page.tsx   # ONLY place for prices
│   └── contact/page.tsx
├── api/
│   ├── register/route.ts
│   ├── newsletter/route.ts
│   └── book/route.ts
├── layout.tsx             # Root layout
├── globals.css            # Global styles
└── not-found.tsx

components/
├── layout/
│   ├── Header.tsx
│   ├── Footer.tsx
│   └── ConditionalLayout.tsx
├── ui/
│   ├── AnimatedSection.tsx
│   ├── LoadingSkeleton.tsx
│   └── [shared components]
└── [feature components]

lib/
├── analytics.ts
├── form-config.ts
└── utils.ts

public/
├── images/
│   ├── [all WebP images ≤350KB]
│   └── hero/
├── icons/
└── fonts/
```

