</div>
```

### Images
```tsx
import Image from 'next/image'

<Image
  src="/images/example.webp"
  alt="Descriptive alt text under 125 characters"
  width={1200}
  height={800}
  loading="lazy"
  decoding="async"
  className="object-cover w-full h-full"
  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
/>
```

