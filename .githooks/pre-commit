#!/usr/bin/env bash
# .githooks/pre-commit — Project Operating Kit: SoT mirror auto-refresh
# Project: lbta-website-draft-3-5-26
# Generated by project-kit-apply.sh on 2026-06-22
#
# Event-driven (fires on git commit), scoped to this repo, no cron, no background lane.
# When an SoT-related file is committed, refreshes docs/source-of-truth/*.json mirror.
# No-op-safe: if the export script doesn't exist yet, exits cleanly.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
EXPORT_SCRIPT="$REPO_ROOT/scripts/export-sot.cjs"
SOT_DIR="$REPO_ROOT/docs/source-of-truth"

# Check if any staged files look like SoT-related content
STAGED=$(git diff --cached --name-only 2>/dev/null || true)

SOT_TOUCHED=0
while IFS= read -r file; do
  case "$file" in
    docs/PROJECT_SOURCE_OF_TRUTH.md|\
    docs/BUILD_LANES.md|\
    docs/NEXT_TERMINAL_HANDOFF.md|\
    docs/source-of-truth/*|\
    scripts/sot*.cjs|\
    scripts/export-sot.cjs)
      SOT_TOUCHED=1
      break
      ;;
  esac
done <<< "$STAGED"

if [ "$SOT_TOUCHED" -eq 0 ]; then
  # No SoT files staged — nothing to do
  exit 0
fi

echo "[pre-commit] SoT file staged — refreshing docs/source-of-truth/ mirror..."

# Guard: export script must exist and node must be available
if [ ! -f "$EXPORT_SCRIPT" ]; then
  echo "[pre-commit] export-sot.cjs not found yet — skipping mirror refresh (no-op)"
  exit 0
fi

if ! command -v node &>/dev/null; then
  echo "[pre-commit] node not found — skipping mirror refresh"
  exit 0
fi

mkdir -p "$SOT_DIR"

if node "$EXPORT_SCRIPT" 2>&1; then
  # Stage any updated mirror files so they land in this commit
  if git ls-files --others --modified "$SOT_DIR/" | grep -q .; then
    git add "$SOT_DIR/"
    echo "[pre-commit] Mirror files staged."
  fi
  echo "[pre-commit] Done."
else
  echo "[pre-commit] Mirror refresh failed (non-fatal) — commit continues."
  exit 0
fi
